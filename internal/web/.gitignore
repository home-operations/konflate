node_modules/

# Built bundles are regenerated by `npm run build` (and in CI/Docker before the
# Go build). index.html carries content-hashed asset names that change on every
# build, so it's not committed; only the static dist/favicon.svg is, anchoring
# the `go:embed all:dist` so the Go binary still builds from a clean checkout.
dist/assets/
dist/index.html

# Playwright + test artifacts
test-results/
playwright-report/
screenshots/
