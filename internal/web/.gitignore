node_modules/

# Built bundles are regenerated by `npm run build` (and in CI/Docker before the
# Go build): index.html with content-hashed assets, the PWA manifest/service
# worker/icons, etc. None are committed — only the static dist/favicon.svg is,
# anchoring the `go:embed all:dist` so the Go binary still builds from a clean
# checkout. Ignore everything under dist except that one anchor.
dist/*
!dist/favicon.svg

# Playwright + test artifacts
test-results/
playwright-report/
screenshots/
